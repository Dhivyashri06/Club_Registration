--CREATE TABLE CLUBS AND INSERT THE CLUB DESCRIPTIONS
CREATE TABLE clubs (
    id SERIAL PRIMARY KEY,
    name VARCHAR(50) UNIQUE NOT NULL,
    description TEXT
);

